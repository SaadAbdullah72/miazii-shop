{
  "type": "AdaptiveCard",
  "body": [
    {
      "type": "TextBlock",
      "size": "Medium",
      "weight": "Bolder",
      "text": "${title}"
    },
    {
      "type": "TextBlock",
      "text": "Last updated: ${lastUpdated}",
      "wrap": true,
      "size": "Small",
      "isSubtle": true
    },
    {
      "type": "FactSet",
      "facts": [
        {
          "title": "${deals[0].name}",
          "value": "${deals[0].price}"
        },
        {
          "title": "${deals[1].name}",
          "value": "${deals[1].price}"
        }
      ]
    }
  ],
  "$schema": "http://adaptivecards.io/schemas/adaptive-card.json",
  "version": "1.5"
}
